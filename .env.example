# Copy this file to .env and fill in real values

GUARDRAIL_PORT=9000
GUARDRAIL_HOST=127.0.0.1
LOG_LEVEL=INFO

# Audit trail — Postgres connection. Recommend a separate database
# (e.g. "guardrail") rather than reusing email-agent's "email_agent" db,
# so this service stays independently deployable.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=guardrail

# Privacy default: matched_span is stored as first_6_chars…last_2_chars.
# Set to "true" only if full forensic detail is needed later — this
# stores the raw matched text (e.g. Aadhaar numbers) unredacted.
GUARDRAIL_AUDIT_STORE_RAW_SPAN=false

# Separate database for pytest (tests/test_audit.py, tests/test_audit_endpoints.py)
# so test runs never touch the real audit trail.
TEST_POSTGRES_DB=guardrail_test
